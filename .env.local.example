# ─────────────────────────────────────────────────────────────────────────────
# .env.local.example — copy to .env.local and fill in your values
# Provided by Medical365 when your clinic is onboarded for local deployment
# ─────────────────────────────────────────────────────────────────────────────

# ── Clinic Identity (given to you by Medical365 support) ─────────────────────
CLINIC_ID=PASTE_YOUR_CLINIC_ID_HERE
CLOUD_API_KEY=PASTE_YOUR_API_KEY_HERE
CLOUD_URL=https://medical365.in

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
DEPLOYMENT_MODE=local

# ── Security (generate a random string, keep secret) ─────────────────────────
JWT_SECRET=GENERATE_A_RANDOM_64_CHAR_STRING_HERE
JWT_EXPIRES_IN=45m
PATIENT_JWT_EXPIRES_IN=8h

# MongoDB Configuration
MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.mongodb.net/?appName=Cluster0

# ── OTP (for patient app login) ───────────────────────────────────────────────
# During setup leave as 'console' — OTPs will print to docker logs
# Change to 'msg91' once you configure MSG91
OTP_PROVIDER=console
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# ── Sync interval (how often stats push to cloud) ─────────────────────────────
SYNC_INTERVAL_MS=900000

# ── ImageKit (for file uploads — optional) ───────────────────────────────────
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINTS=your_imagekit_url
